# =============================================================
# Monitoring Stack Environment Example
# Copy this file to .env and adjust values
# =============================================================

# -------------------------------------------------------------
# Grafana
# -------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=ChangeMe_StrongPassword123!
GRAFANA_DOMAIN=monitoring.example.com
GRAFANA_PORT=3300

# -------------------------------------------------------------
# SMTP for Grafana alert notifications (optional)
# -------------------------------------------------------------
SMTP_ENABLED=false
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
SMTP_PASS=ChangeMe_SMTP_Password
SMTP_TLS_SERVERNAME=mail.example.com
SMTP_SKIP_VERIFY=false
SMTP_STARTTLS_POLICY=OpportunisticStartTLS
SMTP_FROM=alerts@example.com

# -------------------------------------------------------------
# Prometheus basic auth (used by Prometheus UI/API and Grafana datasource)
# -------------------------------------------------------------
PROMETHEUS_BASIC_AUTH_USER=promadmin
PROMETHEUS_BASIC_AUTH_PASSWORD=ChangeMe_PrometheusAuthPassword
