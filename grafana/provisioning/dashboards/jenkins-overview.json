{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Merged Jenkins performance + health dashboard (modernized, no legacy graph/alert panels).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Jenkins Up",
      "datasource": "Prometheus",
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "refId": "A", "expr": "max(up{job=\"jenkins\",server=~\"$server\"})", "instant": true, "range": false }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Health Score",
      "datasource": "Prometheus",
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "refId": "A", "expr": "max(jenkins_health_check_score{job=\"jenkins\",server=~\"$server\"})", "instant": true, "range": false }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "decimals": 2, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 1 }] } }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Executor Usage (%)",
      "datasource": "Prometheus",
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "refId": "A", "expr": "(sum(default_jenkins_executors_busy{job=\"jenkins\",server=~\"$server\"}) / clamp_min(sum(default_jenkins_executors_online{job=\"jenkins\",server=~\"$server\"}),1)) * 100", "instant": true, "range": false }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "showThresholdMarkers": true, "showThresholdLabels": false },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 85 }, { "color": "red", "value": 95 }] } }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Queue Length",
      "datasource": "Prometheus",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "refId": "A", "expr": "sum(default_jenkins_executors_queue_length{job=\"jenkins\",server=~\"$server\"})", "instant": true, "range": false }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] } }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Processing Speed",
      "datasource": "Prometheus",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "refId": "A", "expr": "sum(rate(jenkins_job_building_duration_count{job=\"jenkins\"}[1m]))" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 6 }, { "color": "red", "value": 10 }] } }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Queued Rate",
      "datasource": "Prometheus",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "targets": [{ "refId": "A", "expr": "sum(rate(jenkins_job_queuing_duration_count{job=\"jenkins\"}[1m]))" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 80 }, { "color": "red", "value": 120 }] } }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Job Queue Duration",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 5 },
      "targets": [{ "refId": "A", "expr": "jenkins_job_queuing_duration{job=\"jenkins\"}" }],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Executors (Busy / Online / Available)",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 5 },
      "targets": [
        { "refId": "A", "expr": "sum by(server) (default_jenkins_executors_busy{job=\"jenkins\",server=~\"$server\"})", "legendFormat": "{{server}} busy" },
        { "refId": "B", "expr": "sum by(server) (default_jenkins_executors_online{job=\"jenkins\",server=~\"$server\"})", "legendFormat": "{{server}} online" },
        { "refId": "C", "expr": "sum by(server) (default_jenkins_executors_available{job=\"jenkins\",server=~\"$server\"})", "legendFormat": "{{server}} available" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "CPU Usage (JVM)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 12 },
      "targets": [{ "refId": "A", "expr": "max(vm_cpu_load{job=\"jenkins\"}) * 100", "instant": true, "range": false }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 50 }, { "color": "red", "value": 80 }] } }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Memory Usage",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 12 },
      "targets": [{ "refId": "A", "expr": "max(vm_memory_total_used{job=\"jenkins\"})", "instant": true, "range": false }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "decbytes" }, "overrides": [] }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "JVM Uptime",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 12 },
      "targets": [{ "refId": "A", "expr": "max(vm_uptime_milliseconds{job=\"jenkins\"}) / 1000", "instant": true, "range": false }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Nodes Offline",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 12 },
      "targets": [{ "refId": "A", "expr": "max(jenkins_node_offline_value{job=\"jenkins\"})", "instant": true, "range": false }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "0": { "text": "None" } } }], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Failed Jobs",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 12 },
      "targets": [{ "refId": "A", "expr": "max(jenkins_runs_failure_total{job=\"jenkins\"})", "instant": true, "range": false }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Successful Jobs",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 12 },
      "targets": [{ "refId": "A", "expr": "max(jenkins_runs_success_total{job=\"jenkins\"})", "instant": true, "range": false }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Last Build Duration (ms)",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "targets": [{ "refId": "A", "expr": "default_jenkins_builds_last_build_duration_milliseconds{job=\"jenkins\"}" }],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Queue Size Trend",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "targets": [{ "refId": "A", "expr": "jenkins_queue_size_value{job=\"jenkins\"}" }],
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["jenkins", "cicd", "prometheus"],
  "templating": {
    "list": [
      {
        "name": "server",
        "label": "Server",
        "type": "query",
        "datasource": "Prometheus",
        "definition": "label_values(up{job=\"jenkins\"}, server)",
        "query": {
          "query": "label_values(up{job=\"jenkins\"}, server)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
  },
  "timezone": "browser",
  "title": "Jenkins: Performance and Health Overview",
  "uid": "jenkins-overview",
  "version": 2,
  "weekStart": ""
}
