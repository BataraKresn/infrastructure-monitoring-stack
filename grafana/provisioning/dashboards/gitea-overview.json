      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(process_resident_memory_bytes{job=\"gitea\",instance=~\"$instance\"})",
          "legendFormat": "process_resident_memory"
        },
        {
          "refId": "B",
          "expr": "max(go_memstats_alloc_bytes{job=\"gitea\",instance=~\"$instance\"})",
          "legendFormat": "go_memstats_alloc"
        },
        {
          "refId": "C",
          "expr": "max(go_memstats_heap_inuse_bytes{job=\"gitea\",instance=~\"$instance\"})",
          "legendFormat": "go_heap_inuse"
