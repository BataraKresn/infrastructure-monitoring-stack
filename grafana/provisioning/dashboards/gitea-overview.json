{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Gitea metrics dashboard (Prometheus scrape job: gitea)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Gitea Target Status",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{job=\"gitea\",instance=~\"$instance\"})",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Requests (range)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(promhttp_metric_handler_requests_total{job=\"gitea\",instance=~\"$instance\"}[$__range]))",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "CPU Usage (cores)",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(process_cpu_seconds_total{job=\"gitea\",instance=~\"$instance\"}[5m]))",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 3 }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Uptime",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(time() - process_start_time_seconds{job=\"gitea\",instance=~\"$instance\"})",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Goroutines",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(go_goroutines{job=\"gitea\",instance=~\"$instance\"})",
          "instant": true,
          "range": false
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Request Rate (RPS)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(promhttp_metric_handler_requests_total{job=\"gitea\",instance=~\"$instance\"}[$__rate_interval]))",
          "legendFormat": "RPS"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "4xx / 5xx Error Rate",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(promhttp_metric_handler_requests_total{job=\"gitea\",instance=~\"$instance\",code=~\"4..\"}[$__rate_interval]))",
          "legendFormat": "4xx"
        },
        {
          "refId": "B",
          "expr": "sum(rate(promhttp_metric_handler_requests_total{job=\"gitea\",instance=~\"$instance\",code=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Endpoint Response Duration (scrape)",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(scrape_duration_seconds{job=\"gitea\",instance=~\"$instance\"})",
          "legendFormat": "avg"
        },
        {
          "refId": "B",
          "expr": "max(scrape_duration_seconds{job=\"gitea\",instance=~\"$instance\"})",
          "legendFormat": "max"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
